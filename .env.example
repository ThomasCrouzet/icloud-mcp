# Copy to .env for local use (never commit .env).
# An MCP host can also pass these variables directly in its own
# configuration; see README.md.

# iCloud email address (Apple ID). Supports the file:// prefix to read the
# value from a file (Docker-secret pattern): ICLOUD_EMAIL=file:///run/secrets/icloud-email
ICLOUD_EMAIL=

# iCloud APP-SPECIFIC password (NOT the main account password), generated
# at https://appleid.apple.com. Supports the file:// prefix:
# ICLOUD_PASSWORD=file:///run/secrets/icloud-password
ICLOUD_PASSWORD=

# 1 or true = the create_event/update_event/delete_event tools are NOT
# registered (absent from tools/list). Recommended initial deployment mode.
ICLOUD_MCP_READ_ONLY=1

# Log level for the structured JSON logs on stderr: debug, info, warn, error
# (default info). Set to debug to troubleshoot discovery/shard issues.
# ICLOUD_MCP_LOG_LEVEL=info

# IANA timezone (e.g. Europe/Paris) used to interpret a create_event/
# update_event/search_events start/end value that has NO explicit RFC3339
# offset (e.g. "2026-07-01T14:00:00", no "Z", no "+02:00"). Recommended for
# non-UTC calendar owners: removes DST offset arithmetic from the agent.
# Defaults to UTC if unset. Invalid values fail fast at boot. Affects how
# input is parsed only; events are always written to iCloud as UTC.
ICLOUD_MCP_DEFAULT_TZ=Europe/Paris
